{
  "name": "drift-detector",
  "version": "1.0.0",
  "private": true,
  "description": "A local-first infrastructure drift detection & reconciliation tool: declare desired state, scan a mock cloud for drift, see exactly what diverged, and converge it back.",
  "workspaces": [
    "shared",
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "npm run dev -w backend",
    "dev:web": "npm run dev -w frontend",
    "build": "npm run build -w frontend",
    "test": "npm run test -w backend"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "engines": {
    "node": ">=22.5.0"
  }
}
